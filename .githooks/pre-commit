#!/usr/bin/env bash
set -e

# Run golangci-lint on staged Go files only.
# Install: make setup-hooks

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.go')
if [ -z "$STAGED_GO_FILES" ]; then
    exit 0
fi

if ! command -v golangci-lint &> /dev/null; then
    echo "golangci-lint not found. Install with: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest"
    exit 1
fi

echo "Running golangci-lint..."
golangci-lint run --new-from-rev=HEAD ./...
